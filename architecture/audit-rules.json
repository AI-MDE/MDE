{
  "audit_required": true,
  "audit_scope": [
    "workflow_state_changes",
    "approval_decisions",
    "policy_exceptions",
    "security_relevant_changes"
  ],
  "audit_event_shape": {
    "event_id": "uuid",
    "entity_type": "string",
    "entity_id": "uuid",
    "event_type": "string",
    "actor_id": "string",
    "occurred_at": "timestamp",
    "payload": "json"
  },
  "entity_change_attribution": {
    "required_for_business_state_entities": true,
    "required_fields": [
      "created_at",
      "created_by_user_id",
      "updated_at",
      "updated_by_user_id"
    ],
    "decision_actor_in_audit_required": true,
    "decision_actor_on_master_entity_allowed": false
  },
  "immutability": {
    "append_only": true,
    "updates_allowed": false
  }
}
