{
  "dto_policy": {
    "use_dto": true,
    "apply_to_layers": [
      "controller",
      "service"
    ],
    "forbid_direct_entity_exposure": true,
    "mapping_layers": [
      "controller",
      "service"
    ],
    "request_dto_suffix": "RequestDto",
    "response_dto_suffix": "ResponseDto"
  },
  "api_rules": {
    "must_define_error_contracts": true,
    "must_define_validation_errors": true,
    "prefer_versioned_external_apis": true
  }
}