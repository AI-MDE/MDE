{
  "name": "ai-mde",
  "version": "1.1.0",
  "private": true,
  "scripts": {

    "_note_1": "----- MDE Viewer scripts -----",

    "create-project": "node scripts/create-project.js",
    "validate:ai": "node tools/validate-mde-consistency.js",
    "command-zip": "node mde/scripts/generate-command-zip.js",
    "validate": "node mde/tools/validate-config.js configuration.json",
    "build:viewer": "tsc web/viewer.ts --outDir web --module commonjs --target es2020 --esModuleInterop true --skipLibCheck",
    "viewer": "node web/app.js",
    "test:api": "node tests/test-web-viewer.js",
    "test:browser": "node tests/test-viewer-browser.js",
    "test:viewer": "npm run test:api && npm run test:browser",
    "demo": "ts-node src/demo/app.js",
    "test": "jest",

    "_note_2": "---------Target App Scripts------------",

    "typecheck_s": "tsc --noEmit",
    "seed_s": "ts-node src.sample/seed/seed.ts",
    "start_s": "ts-node src.sample/server.ts",

    "_note_3": "---------Target App Scripts------------",

    "typecheck": "tsc --noEmit",
    "seed": "ts-node src.target/seed/seed.ts",
    "start": "ts-node src.target/server.ts"

  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "ejs": "^5.0.1",
    "express": "^5.2.1",
    "method-override": "^3.0.0",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.12",
    "@types/method-override": "^3.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "mermaid": "^11.13.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.4"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/*.spec.ts"
    ]
  }
}
