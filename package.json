{
  "name": "ai-mde",
  "version": "1.1.0",
  "private": true,
  "scripts": {
    "_note_1": "----- MDE Viewer scripts -----",
    "create-project": "node scripts/create-project.js",
    "validate:ai": "node tools/validate-mde-consistency.js",
    "command-zip": "node mde/scripts/generate-command-zip.js",
    "validate": "node mde/tools/validate-config.js configuration.json",
    "viewer": "ts-node web/app.ts --root=../leaveManagement/",
    "_note_2": "---------Internal commands ------------",
    "build:viewer": "tsc web/viewer.ts --outDir web --module commonjs --target es2020 --esModuleInterop true --skipLibCheck",
    "build": "tsc -p tsconfig.json",
    "test:api": "node tests/test-web-viewer.js",
    "test:browser": "node tests/test-viewer-browser.js",
    "test": "jest",
    "test:viewer": "npm run test:api && npm run test:browser"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "dotenv": "^16.6.1",
    "ejs": "^5.0.1",
    "express": "^5.2.1",
    "method-override": "^3.0.0",
    "pg": "^8.12.0",
    "undici": "^7.24.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.12",
    "@types/method-override": "^3.0.0",
    "@types/node": "^22.10.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "mermaid": "^11.13.0",
    "rimraf": "^6.0.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/*.spec.ts"
    ]
  }
}
