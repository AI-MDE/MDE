{
  "title": "MDE Documentation Viewer",
  "version": "1.0.0",
  "generated_from": "mde/methodology/methodology.json",
  "config": "configuration.json",
  "sections": [
    {
      "id": "project-initiation",
      "label": "Project Initiation",
      "phase": "project_initiation",
      "icon": "gear",
      "items": [
        { "id": "configuration",        "label": "Configuration",        "docType": "root-configuration",  "file": "configuration.json" },
        { "id": "application",          "label": "Application Definition","docType": "application",         "file": "$config.application.definition" },
        { "id": "project-state",        "label": "Project State",        "docType": "project-state",       "file": "$config.project_state.state" },
        { "id": "command-log",          "label": "Command Log",          "docType": "command-log",         "file": "$config.project_state.commandLog" }
      ]
    },
    {
      "id": "business-analysis",
      "label": "Business Analysis",
      "phase": "business_analysis",
      "icon": "document-text",
      "items": [
        { "id": "requirements",         "label": "Requirements",         "docType": "requirements",        "file": "$config.ba.requirements/requirements.md" },
        { "id": "analysis-status",      "label": "Analysis Status",      "docType": "analysis-status",     "file": "$config.ba.analysisStatus" },
        { "id": "glossary",             "label": "Glossary",             "docType": "glossary",            "file": "$config.ba.glossary",   "includeIfExists": true },
        { "id": "business-functions",   "label": "Business Functions",   "docType": "business-functions",  "file": "$config.ba.businessFunctions" },
        {
          "id": "ldm",
          "label": "Logical Data Model",
          "docType": "logical-data-model",
          "scan": {
            "dir": "$config.design.ldm",
            "pattern": ".*\\.json$",
            "recursive": true,
            "labelFrom": "filename",
            "sortBy": "filename"
          }
        },
        { "id": "diagram-ldm",           "label": "Logical Data Model",   "docType": "markdown", "file": "docs/diagrams/ldm.md",                "includeIfExists": true },
        {
          "id": "use-cases",
          "label": "Use Cases",
          "docType": "use-case",
          "scan": {
            "dir": "$config.ba.useCases",
            "pattern": "$config.ba.useCasePattern",
            "labelFrom": "title",
            "sortBy": "filename"
          }
        },
        {
          "id": "qa",
          "label": "Q&A",
          "items": [
            { "id": "completed-questions", "label": "Completed Questions", "docType": "completed-questions", "file": "$config.project_state.completedQuestions" },
            { "id": "open-queue",          "label": "Open Queue",          "docType": "open-queue",          "file": "$config.project_state.openQueue" },
            { "id": "questions",           "label": "Active Questions",    "docType": "questions-batch",     "file": "$config.project_state.questions" }
          ]
        }
      ]
    },
    {
      "id": "system-design",
      "label": "System Design",
      "phase": "system_design",
      "icon": "cube",
      "items": [
        { "id": "architecture",    "label": "Application Architecture", "docType": "architecture",       "file": "$config.design.appArchitecture" },
        { "id": "diagram-architecture",  "label": "Architecture",         "docType": "markdown", "file": "docs/diagrams/architecture.md",       "includeIfExists": true },
        { "id": "diagram-flow",          "label": "Leave Request Interaction Flow",   "docType": "markdown", "file": "docs/diagrams/leave-request-flow.md", "includeIfExists": true },
        { "id": "diagram-workflow",      "label": "Leave Request BPMN Workflow","docType": "markdown", "file": "docs/diagrams/leave-request-bpmn.md", "includeIfExists": true },
        { "id": "diagram-dataflow",      "label": "Data Flow",            "docType": "markdown", "file": "docs/diagrams/dataflow.md",           "includeIfExists": true },
        { "id": "diagram-ui-navigation", "label": "UI Navigation",        "docType": "markdown", "file": "docs/diagrams/ui-navigation.md",      "includeIfExists": true },
        { "id": "diagram-pdm",           "label": "Physical Data Model",  "docType": "markdown", "file": "docs/diagrams/pdm.md",                "includeIfExists": true },
        {
          "id": "entities",          "label": "Entities",          "docType": "entity",          
                                    "scan": { "dir": "$config.design.entities", "pattern": "$config.design.entityPattern", "labelFrom": "entity.name", "sortBy": "entity.id" }
        },
        {
          "id": "sql",            "label": "Database Schema",  "items": [
            { "id": "schema-sql",   "label": "Schema DDL",   "docType": "sql",          "file": "$config.design.sql/schema.sql" },
            { "id": "schema-state", "label": "Schema State", "docType": "schema-state", "file": "$config.design.sql/schema-state.json" }
          ]
        }
      ]
    },
    {
      "id": "modules",
      "label": "Modules",
      "phase": "system_design",
      "icon": "puzzle",
      "items": [
        { "id": "module-catalog", "label": "Module Catalog", "docType": "module-catalog", "file": "$config.design.moduleCatalog" },
        {
          "id": "module-specs",
          "label": "Module Specs",
          "docType": "module-charter",
          "scan": {
            "dir": "$config.design.modules",
            "pattern": "^module-.*\\.md$",
            "recursive": true,
            "labelFrom": "title",
            "groupBy": "parent-folder",
            "sortBy": "filename"
          }
        }
      ]
    },
    {
      "id": "ui-design",
      "label": "UI Design",
      "phase": "system_design",
      "icon": "device-phone-mobile",
      "items": [
        { "id": "ui-catalog", "label": "UI Catalog", "docType": "ui-catalog", "file": "$config.design.uiModules/ui-catalog.json", "includeIfExists": true },
        {
          "id": "ui-module-specs",
          "label": "UI Modules",
          "docType": "ui-module-spec",
          "scan": {
            "dir": "$config.design.uiModules",
            "pattern": "^ui-(?!catalog).*\\.json$",
            "labelFrom": "moduleName",
            "sortBy": "moduleId"
          }
        }
      ]
    },
    {
      "id": "governance",
      "label": "Governance",
      "phase": "governance",
      "icon": "chart-bar",
      "items": [
        {
          "id": "diagrams",
          "label": "Diagrams",
          "items": [
            { "id": "diagram-ldm",           "label": "Logical Data Model",   "docType": "markdown", "file": "docs/diagrams/ldm.md",                "includeIfExists": true },
            { "id": "diagram-architecture",  "label": "Architecture",         "docType": "markdown", "file": "docs/diagrams/architecture.md",       "includeIfExists": true },
            { "id": "diagram-flow",          "label": "Leave Request Interaction Flow",   "docType": "markdown", "file": "docs/diagrams/leave-request-flow.md", "includeIfExists": true },
            { "id": "diagram-workflow",      "label": "Leave Request BPMN Workflow","docType": "markdown", "file": "docs/diagrams/leave-request-bpmn.md", "includeIfExists": true },
            { "id": "diagram-dataflow",      "label": "Data Flow",            "docType": "markdown", "file": "docs/diagrams/dataflow.md",           "includeIfExists": true },
            { "id": "diagram-ui-navigation", "label": "UI Navigation",        "docType": "markdown", "file": "docs/diagrams/ui-navigation.md",      "includeIfExists": true },
            { "id": "diagram-pdm",           "label": "Physical Data Model",  "docType": "markdown", "file": "docs/diagrams/pdm.md",                "includeIfExists": true }
          ]
        }
      ]
    },
    {
      "id": "development",
      "label": "Development",
      "phase": "development",
      "icon": "code",
      "items": [
        {
          "id": "sample-data",
          "label": "Sample Data",
          "docType": "sample-data",
          "scan": {
            "dir": "$config.output.src/../output/sample-data",
            "pattern": ".*\\.json$",
            "labelFrom": "filename",
            "sortBy": "filename"
          }
        },
        {
          "id": "ui-source-code",
          "label": "UI Source Code",
          "docType": "ui-source-code",
          "scan": {
            "dir": "$config.output.uiSrc",
            "pattern": ".*\\.(tsx|ts|css)$",
            "recursive": true,
            "groupBy": "parent-folder",
            "sortBy": "filename"
          }
        },
        {
          "id": "source-code",
          "label": "Source Code",
          "docType": "source-code",
          "scan": {
            "dir": "$config.output.src",
            "pattern": ".*\\.ts$",
            "recursive": true,
            "groupBy": "module-folder",
            "sortBy": "filename"
          }
        },
        {
          "id": "tests",
          "label": "Tests",
          "items": [
            {
              "id": "unit-tests",
              "label": "Unit Tests",
              "docType": "source-code",
              "scan": {
                "dir": "$config.test.unit",
                "pattern": "$config.test.unitPattern",
                "recursive": true,
                "groupBy": "module-folder",
                "sortBy": "filename"
              }
            },
            {
              "id": "integration-tests",
              "label": "Integration Tests",
              "docType": "source-code",
              "scan": {
                "dir": "$config.test.integration",
                "pattern": "$config.test.integrationPattern",
                "recursive": true,
                "groupBy": "module-folder",
                "sortBy": "filename"
              }
            }
          ]
        }
      ]
    },
    {
      "id": "mde-framework",
      "label": "MDE Framework",
      "icon": "cog",
      "items": [
        {
          "id": "methodology",
          "label": "Methodology",
          "docType": "methodology",
          "file": "$config.mde.methodology/methodology.json"
        },
        {
          "id": "orchestrator",
          "label": "Orchestrator",
          "docType": "orchestrator",
          "file": "$config.mde.orchestrator"
        },
        {
          "id": "ai-commands",
          "label": "Commands",
          "docType": "mde-command",
          "scan": {
            "dir": "$config.mde.commands",
            "pattern": ".*\\.json$",
            "recursive": true,
            "labelFrom": "label",
            "groupBy": "phase",
            "groupByOrder": ["project_initiation", "business_analysis", "system_design", "design", "development", "governance"]
          }
        },
        {
          "id": "ai-skills",
          "label": "Skills",
          "docType": "mde-skill",
          "scan": {
            "dir": "$config.mde.skills",
            "pattern": ".*\\.json$",
            "recursive": true,
            "labelFrom": "name",
            "groupBy": "parent-folder",
            "sortBy": "filename"
          }
        }
      ]
    }
  ]
}

