{
  "project": {
    "name": "My Project",
    "type": "application",
    "version": "0.1.0",
    "methodology": "Model-Driven Engineering",
    "description": "",
    "author": ""
  },

  "mde": {
    "path":         "{ai-mde-path}",

    "_note_1": "These file are using in the AI calls.",

    "orchestrator": "{ai-mde-path}/ai-instructions/orchestrator.json",
    "commands":     "{ai-mde-path}/ai-instructions/commands/",
    "skills":       "{ai-mde-path}/ai-instructions/skills/",
    "architecture": "{ai-mde-path}/architecture/",
    "methodology":  "{ai-mde-path}/methodology/"
  },

  "ba": {
    "requirements":      "ba/requirements.md",
    "analysisStatus":    "ba/analysis-status.md",
    "glossary":          "ba/glossary.md",
    "discovery":         "ba/discovery",
    "analyzed":          "ba/analyzed",
    "useCases":          "ba/use-cases",
    "useCasePattern":    "ba/use-cases/uc-*.md",
    "businessFunctions": "ba/business-functions.json",
    "ldm":               "ba/data-model"
  },

  "design": {
    "entities":        "design/entities",
    "entityPattern":   "design/entities/ent-*.json",
    "appArchitecture": "design/application_architecture.json",
    "moduleCatalog":   "design/modules/module-catalog.json",
    "modules":         "design/modules",
    "uiModules":       "design/modules/ui",
    "sql":             "design/sql",
    "schema":          "design/sql/schema.json"
  },

  "project_state": {
    "state":              "project/project-state.json",
    "questions":          "project/questions.json",
    "openQueue":          "project/open-queue.json",
    "completedQuestions": "project/completed-Questions.json",
    "commandLog":         "project/logs/command-log.jsonl",
    "methodology":        "project/methodology.json"
  },

  "application": {
    "definition": "application/application.json"
  },

  "scripts": {
    "setupDb":  "scripts/sql/setup-db.sh",
    "seedData": "scripts/loadSeedData.js"
  },

  "ui": {
    "framework":   "react",
    "language":    "typescript",
    "router":      "react-router-dom",
    "styling":     "tailwind",
    "stateClient": "tanstack-query",
    "authScheme":  "jwt-bearer",
    "apiProxy":    "http://localhost:3000"
  },

  "output": {
    "src":      "src",
    "uiSrc":    "ui/src",
    "commands": "output/commands",
    "docs":     "docs"
  },

  "test": {
    "root":               "test",
    "unit":               "test/unit",
    "integration":        "test/integration",
    "unitPattern":        "test/unit/**/*.test.ts",
    "integrationPattern": "test/integration/**/*.test.ts",
    "framework":          "jest"
  }
