{
  "name": "diagram_generation",
  "purpose": "Generate diagrams from core artifacts",
  "inputs": {
    "ldm": {
      "from": "config.ba.ldmFile",
      "default": "ba/data-model/logical-data-model.json"
    },
    "appArchitecture": {
      "from": "config.design.appArchitecture",
      "default": "design/application_architecture.json"
    },
    "catalog": {
      "from": "config.design.moduleCatalog",
      "default": "design/modules/module-catalog.json"
    }
  },
  "outputs": {
    "diagrams": {
      "to": "config.output.docs",
      "pattern": "diagrams/*.md"
    },
    "moduleInteractionDiagram": {
      "to": "config.output.docs",
      "pattern": "diagrams/module-interaction-by-name.md"
    }
  },
  "artifacts": [
    {
      "from": "config.output.docs",
      "default": "output/docs"
    }
  ],
  "rules": [
    "Render LDM, architecture, interaction, and dataflow diagrams",
    "Render a dedicated module interaction diagram using module names as nodes and labels",
    "Derive module-to-module links from canonical architecture and module catalog dependencies",
    "Use canonical sources as inputs"
  ],
  "uses_tools": [
    "file_manager"
  ],
  "next_phase": "governance"
}
