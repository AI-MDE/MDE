{
  "name": "logical_data_model",
  "purpose": "Generate a logical data model grounded in requirements, glossary, and architecture",
  "inputs": {
    "requirements": {
      "from": "config.ba.requirements",
      "default": "ba/requirements.md"
    },
    "glossary": {
      "from": "config.ba.glossary",
      "default": "ba/glossary.md"
    },
    "appArchitecture": {
      "from": "config.design.appArchitecture",
      "default": "design/application_architecture.json"
    }
  },
  "outputs": {
    "ldm": {
      "from": "config.ba.ldmFile",
      "default": "ba/data-model/logical-data-model.json"
    }
  },
  "artifacts": [
    {
      "from": "config.ba.ldmFolder",
      "default": "ba/data-model"
    }
  ],
  "rules": [
    "Use business vocabulary",
    "Separate conceptual entities from physical implementation",
    "Record ownership and relationships explicitly"
  ],
  "uses_tools": [
    "file_manager",
    "json_validator"
  ],
  "next_phase": "module_definition"
}
