{
  "name": "module_definition",
  "purpose": "Produce a complete module definition per module in the catalog — combining charter (ownership, boundaries, interfaces, dependencies) and spec (schema, rules, state machine, events, API) into a single implementation-ready artifact.",
  "inputs": {
    "catalog": {
      "from": "config.design.moduleCatalog",
      "default": "design/modules/module-catalog.json"
    },
    "entities": {
      "from": "config.design.entityPattern",
      "default": "design/entities/ent-*.json"
    },
    "requirements": {
      "from": "config.ba.requirements",
      "default": "ba/requirements.md"
    },
    "architecture": {
      "from": "config.mde.architecture",
      "default": "mde/architecture/architecture.json"
    }
  },
  "outputs": {
    "moduleJson": {
      "to": "config.design.modules",
      "pattern": "{moduleType}/module-{kebab-module}.json"
    },
    "moduleMd": {
      "to": "config.design.modules",
      "pattern": "{moduleType}/module-{kebab-module}.md"
    }
  },
  "artifacts": [
    {
      "from": "config.design.modules",
      "default": "design/modules"
    }
  ],
  "output_folder": {
    "to": "config.design.modules",
    "pattern": "{moduleType}/"
  },
  "output_shape": {
    "json": {
      "moduleId": "from catalog",
      "moduleName": "from catalog",
      "table": "from catalog — null for non-entity modules",
      "moduleType": "from catalog",
      "entityRef": "from catalog — null for non-entity modules",
      "generates": "from catalog",
      "charter": {
        "responsibilities": "array of strings — what this module owns and enforces",
        "exclusions": "array of strings — what this module explicitly does NOT do, and which module owns it instead",
        "dependencies": [
          {
            "moduleId": "Mxx",
            "moduleName": "string",
            "reason": "one sentence"
          }
        ],
        "requirementMapping": [
          {
            "ruleId": "BR-xxx",
            "mappedTo": "domain | data_access | service | query_service",
            "artifact": "ClassName",
            "description": "one sentence"
          }
        ]
      },
      "spec": {
        "schema": {
          "table": "snake_case table name",
          "columns": [
            {
              "name": "column_name",
              "type": "uuid | string | integer | decimal | boolean | date | datetime | enum",
              "required": true,
              "default": null,
              "enum": [],
              "description": "optional"
            }
          ],
          "indexes": [
            {
              "fields": [],
              "unique": false,
              "where": null,
              "description": "optional"
            }
          ]
        },
        "interfaces": {
          "service": [
            {
              "layer": "service",
              "name": "methodName",
              "command": "XCommand",
              "response": "XResponseDto",
              "signature": "execute(cmd: XCommand, actor: ActorContext): Promise<XResponseDto>",
              "steps": [
                "authorize",
                "load",
                "domain behavior",
                "save",
                "emit event"
              ],
              "description": "one sentence",
              "errorConditions": [
                "ErrorClassName — when condition"
              ]
            }
          ],
          "query_service": [
            {
              "layer": "query_service",
              "name": "methodName",
              "filters": "XFilterParams",
              "response": "XReadDto",
              "signature": "methodName(filters: XFilterParams): Promise<XReadDto[]>",
              "description": "one sentence",
              "tablesJoined": []
            }
          ]
        },
        "rules": [
          {
            "id": "RULE-MOD-nn",
            "name": "string",
            "layer": "domain | service | controller",
            "artifact": "ClassName",
            "condition": "string",
            "action": "string",
            "elseAction": "string"
          }
        ],
        "stateMachine": {
          "note": "workflow module type only",
          "states": [],
          "initial": "string",
          "transitions": [
            {
              "from": "string",
              "to": "string",
              "event": "string",
              "guard": "rule ID or none",
              "actions": []
            }
          ]
        },
        "api": [
          {
            "method": "POST | GET | PUT | PATCH | DELETE",
            "path": "/api/{resource}",
            "requestDto": "XRequestDto",
            "responseDto": "XResponseDto | XReadDto",
            "description": "one sentence"
          }
        ],
        "events": {
          "published": [
            {
              "eventType": "string",
              "trigger": "service method name",
              "payloadFields": []
            }
          ]
        }
      },
      "optimisticLocking": "boolean from catalog",
      "auditRequired": "boolean from catalog"
    },
    "md": "Human-readable rendering of the full module definition using markdown tables and sections"
  },
  "module_type_rules": {
    "workflow": {
      "generates": [
        "dto",
        "data_access",
        "domain",
        "service",
        "query_service"
      ],
      "domain_artifacts": [
        "Entity",
        "Validator",
        "StateMachine"
      ],
      "spec_required": [
        "schema",
        "interfaces",
        "rules",
        "stateMachine",
        "api",
        "events"
      ],
      "must_have": [
        "stateMachine block derived from entity file",
        "auditRequired: true"
      ]
    },
    "master_data": {
      "generates": [
        "dto",
        "data_access",
        "domain",
        "service",
        "query_service"
      ],
      "domain_artifacts": [
        "Entity",
        "Validator"
      ],
      "spec_required": [
        "schema",
        "interfaces",
        "rules",
        "api"
      ],
      "must_have": [
        "optimisticLocking: true"
      ]
    },
    "rule_engine": {
      "generates": [
        "dto",
        "data_access",
        "domain",
        "service"
      ],
      "domain_artifacts": [
        "Entity",
        "Rules"
      ],
      "spec_required": [
        "schema",
        "interfaces",
        "rules",
        "api",
        "events"
      ],
      "must_have": [
        "auditRequired: true"
      ],
      "note": "Typically append-only — set optimisticLocking: false when entity is immutable"
    },
    "integration": {
      "generates": [
        "dto",
        "data_access",
        "service"
      ],
      "domain_artifacts": [],
      "spec_required": [
        "schema",
        "interfaces",
        "api",
        "events"
      ],
      "must_have": [
        "optimisticLocking: false"
      ],
      "note": "No domain layer. Failures must not propagate to caller."
    },
    "reporting": {
      "generates": [
        "query_service"
      ],
      "domain_artifacts": [],
      "spec_required": [
        "interfaces.query_service",
        "api"
      ],
      "must_have": [
        "table: null",
        "entityRef: null"
      ],
      "note": "query_service only — no schema, no data_access, no domain, no service layer."
    }
  },
  "naming_rules": {
    "output_folder": "design/modules/{moduleType}/",
    "json_file": "module-{kebab-case-moduleName}.json",
    "md_file": "module-{kebab-case-moduleName}.md",
    "dto_suffixes": "Command for write inputs; RequestDto for API input; ResponseDto for write output; ReadDto for query output",
    "api_path": "/api/{kebab-case-plural-resource}",
    "cross_module_calls": "service calls other modules via their service interface only — never data_access or domain directly",
    "cross_module_reads": "query_service calls other modules via their query_service only"
  },
  "rules": [
    "Process every module in module-catalog.json — one JSON + one MD per module",
    "Read entityRef file for columns, indexes, rules, stateMachine, relationships — do not re-derive",
    "Set generates[] from catalog — do not invent or omit layers",
    "Apply module_type_rules to determine required spec sections and domain artifacts",
    "Responsibilities and exclusions derived from entity file description and rules",
    "Exclusions must name the delegated module by ID and name",
    "Each service interface method must include errorConditions listing all possible error types",
    "Each service method must include steps: authorize, load, domain behavior, save, emit event",
    "query_service methods must not reference domain layer",
    "DTO naming: Command for write inputs, ReadDto for query outputs, ResponseDto for write outputs",
    "API paths use kebab-case plural resource names",
    "Dependencies list only modules this module calls — not modules that call it",
    "requirementMapping traces each BR to its layer (domain | service | query_service | controller) and artifact",
    "stateMachine required for workflow module type — derive transitions from entity file",
    "events.published required for workflow and rule_engine module types",
    "No new requirements — all content must be traceable to inputs",
    "All state transitions and error conditions must be explicit"
  ],
  "uses_tools": [
    "file_manager",
    "json_validator"
  ],
  "next_phase": "source_code_generation"
}