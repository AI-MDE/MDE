{
  "name": "sample_data_generation",
  "purpose": "Generate sample entity data files",
  "inputs": {
    "ldm": {
      "from": "config.ba.ldmFile",
      "default": "ba/data-model/logical-data-model.json"
    },
    "entities": {
      "from": "config.design.entityPattern",
      "default": "design/entities/ent-*.json"
    }
  },
  "outputs": {
    "sampleData": {
      "to": "config.output.sampleData",
      "pattern": "*.json"
    }
  },
  "artifacts": [
    {
      "from": "config.output.sampleData",
      "default": "output/sample-data"
    }
  ],
  "rules": [
    "Respect field types and required flags",
    "Use deterministic values per entity"
  ],
  "uses_tools": [
    "file_manager"
  ],
  "next_phase": "development"
}