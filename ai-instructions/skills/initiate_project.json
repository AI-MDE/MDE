{
  "name": "initiate_project",
  "purpose": "Initialize a new project with default templates and directory structure",
  "inputs": {},
  "outputs": {
    "requirements": {
      "from": "config.ba.requirements",
      "default": "ba/requirements.md"
    },
    "appArchitecture": {
      "from": "config.design.appArchitecture",
      "default": "design/application_architecture.json"
    },
    "projectState": {
      "from": "config.project_state.state",
      "default": "project/project-state.json"
    }
  },
  "artifacts": [
    {
      "default": "project root"
    }
  ],
  "rules": [
    "Do not overwrite existing files without confirmation",
    "Ensure standard folder structure is created"
  ],
  "uses_tools": [
    "file_manager",
    "json_validator"
  ],
  "next_phase": "business_analysis"
}