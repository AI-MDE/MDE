{
    "name":  "documentation_generation",
    "purpose":  "Render documentation using templates and artifacts",
    "inputs":  [
                   "configuration.json"
               ],
    "outputs":  [
                    "output/docs/*.md"
                ],
    "artifacts":  [
                      "output/docs/"
                  ],
    "rules":  [
