{
  "name": "documentation_generation",
  "purpose": "Render documentation using templates and artifacts",
  "inputs": {
    "config": {
      "default": "configuration.json"
    }
  },
  "outputs": {
    "docs": {
      "to": "config.output.docs",
      "pattern": "*.md"
    }
  },
  "artifacts": [
    {
      "from": "config.output.docs",
      "default": "output/docs"
    }
  ],
  "rules": [
    "Use registered templates",
    "Do not overwrite canonical sources"
  ],
  "uses_tools": [
    "file_manager"
  ],
  "next_phase": "governance"
}