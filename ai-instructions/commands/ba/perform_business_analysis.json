{
  "name":  "perform_business_analysis",
  "label": "Perform Business Analysis",
  "phase": "business_analysis",
  "intent": "analyze_and_clarify",
  "ai":    "required",
  "skill": "business_analysis_from_sources",
  "requires": {
    "sourceFolder":          { "from": "config.ba.discovery",           "default": "ba/discovery" },
    "applicationDefinition": { "from": "config.application.definition", "default": "application/application.json" }
  },
  "produces": {
    "questionBatchFile": { "from": "config.project_state.questions", "default": "project/questions.json" },
    "baDocFile":         { "from": "config.ba.requirements",         "default": "ba/" },
    "queueFile":         { "from": "config.project_state.openQueue", "default": "project/open-queue.json" },
    "statusDocFile":     { "from": "config.ba.analysisStatus",       "default": "ba/analysis-status.md" }
  }
}

