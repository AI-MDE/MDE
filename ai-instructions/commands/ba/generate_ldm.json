{
  "name": "generate_ldm",
  "label": "Generate LDM",
  "phase": "system_design",
  "intent": "generate",
  "ai": "required",
  "requires": {
    "requirements": {
      "from": "config.ba.requirements",
      "default": "ba/"
    },
    "glossary": {
      "from": "config.ba.glossary",
      "default": "ba/glossary.md"
    },
    "appArchitecture": {
      "from": "config.design.appArchitecture",
      "default": "design/application_architecture.json"
    }
  },
  "produces": {
    "ldm": {
      "from": "config.ba.ldmFile",
      "default": "ba/data-model/logical-data-model.json"
    }
  },
  "calls": [
    "logical_data_model"
  ],
  "tools": [
    "file_manager",
    "json_validator"
  ],
  "rules": [
    "Use glossary terms as canonical names",
    "Do not invent entities with no business justification",
    "Map entities to owning modules where possible"
  ]
}
