{
  "name": "generate_erd",
  "label": "Generate ERD",
  "phase": "governance",
  "intent": "generate",
  "ai": "none",
  "requires": {
    "ldm": {
      "from": "config.ba.ldmFile",
      "default": "ba/data-model/logical-data-model.json"
    }
  },
  "produces": {
    "erd": {
      "to": "config.output.docs",
      "pattern": "diagrams/erd.md"
    }
  },
  "calls": [
    "diagram_generation"
  ],
  "tools": [
    "file_manager"
  ],
  "rules": [
    "Generate ERD directly from logical-data-model.json",
    "Do not invent entities or relationships"
  ]
}