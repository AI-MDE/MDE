{
  "name": "build_system_design",
  "label": "Build System Design",
  "phase": "system_design",
  "intent": "generate",
  "ai": "required",
  "requires": {
    "requirements": {
      "from": "config.ba.requirements",
      "default": "ba/requirements.md"
    },
    "useCases": {
      "from": "config.ba.useCasePattern",
      "default": "ba/use-cases/uc-*.md"
    },
    "businessFunctions": {
      "from": "config.ba.businessFunctions",
      "default": "ba/business-functions.json"
    }
  },
  "produces": {
    "appArchitecture": {
      "from": "config.design.appArchitecture",
      "default": "design/application_architecture.json"
    },
    "moduleCatalog": {
      "from": "config.design.moduleCatalog",
      "default": "design/modules/module-catalog.json"
    }
  },
  "calls": [
    "system_design"
  ],
  "tools": [
    "file_manager"
  ],
  "rules": [
    "Must define architectural patterns",
    "Must define component/module boundaries",
    "Must map requirements to modules"
  ]
}