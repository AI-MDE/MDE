{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "requirements.schema.json",
  "title": "Business Requirements Document",
  "description": "Schema for the machine-readable Business Requirements Document produced in Phase 1 (Business Analysis)",
  "type": "object",
  "required": ["project", "version", "date", "status", "goals", "scope", "stakeholders", "constraints", "requirements", "acceptanceCriteria"],
  "additionalProperties": false,

  "properties": {

    "project":  { "type": "string", "description": "Human-readable project name" },
    "version":  { "type": "string", "pattern": "^\\d+\\.\\d+(\\.\\d+)?$", "description": "Semantic version string" },
    "date":     { "type": "string", "format": "date", "description": "ISO 8601 creation or last-updated date" },
    "status":   { "type": "string", "enum": ["draft", "review", "approved", "deprecated"] },

    "goals": {
      "type": "array",
      "description": "High-level business objectives this project must achieve",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },

    "scope": {
      "type": "object",
      "required": ["included", "excluded"],
      "additionalProperties": false,
      "properties": {
        "included": {
          "type": "array", "minItems": 1,
          "items": { "type": "string" },
          "description": "Capabilities and features explicitly in scope"
        },
        "excluded": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Items explicitly out of scope to prevent scope creep"
        }
      }
    },

    "stakeholders": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["role", "group", "interest"],
        "additionalProperties": false,
        "properties": {
          "role":     { "type": "string", "description": "Job title or function name" },
          "group":    { "type": "string", "description": "System group or team identifier" },
          "interest": { "type": "string", "description": "What this stakeholder needs from the system" }
        }
      }
    },

    "constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description"],
        "additionalProperties": false,
        "properties": {
          "id":          { "type": "string", "pattern": "^CON-\\d+$" },
          "description": { "type": "string" }
        }
      }
    },

    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "description", "priority", "source"],
        "additionalProperties": false,
        "properties": {
          "id":          { "type": "string", "pattern": "^BR-\\d+$" },
          "description": { "type": "string", "minLength": 1 },
          "priority":    { "type": "string", "enum": ["must", "should", "could", "wont"] },
          "source":      {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" },
            "description": "IDs or names of the stakeholders or constraints that drive this requirement"
          }
        }
      }
    },

    "businessRules": {
      "type": "array",
      "description": "Optional catalog of business rules derived from requirements",
      "items": {
        "type": "object",
        "required": ["id", "rule", "type"],
        "properties": {
          "id":    { "type": "string", "pattern": "^BRule-\\d+$" },
          "rule":  { "type": "string" },
          "type":  { "type": "string", "enum": ["precondition", "deadline", "branch", "conditional", "timer", "and-join", "validation"] },
          "appliesTo":         { "type": "string" },
          "condition":         { "type": "string" },
          "action":            { "type": "string" },
          "slaHours":          { "type": "integer", "minimum": 1 },
          "requiredConditions":{ "type": "array", "items": { "type": "string" } },
          "escalationRules": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["track", "slaHours"],
              "additionalProperties": false,
              "properties": {
                "track":    { "type": "string" },
                "slaHours": { "type": "integer", "minimum": 1 }
              }
            }
          }
        }
      }
    },

    "glossary": {
      "type": "object",
      "description": "Key domain terms and their definitions",
      "additionalProperties": { "type": "string" }
    },

    "acceptanceCriteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "requirementIds", "criterion"],
        "additionalProperties": false,
        "properties": {
          "id":             { "type": "string", "pattern": "^AC-\\d+$" },
          "requirementIds": {
            "type": "array", "minItems": 1,
            "items": { "type": "string", "pattern": "^BR-\\d+$" }
          },
          "criterion": { "type": "string", "minLength": 1 }
        }
      }
    },

    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "likelihood", "impact", "mitigation"],
        "additionalProperties": false,
        "properties": {
          "id":          { "type": "string", "pattern": "^RISK-\\d+$" },
          "description": { "type": "string" },
          "likelihood":  { "type": "string", "enum": ["low", "medium", "high"] },
          "impact":      { "type": "string", "enum": ["low", "medium", "high"] },
          "mitigation":  { "type": "string" }
        }
      }
    },

    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["system", "purpose"],
        "additionalProperties": false,
        "properties": {
          "system":  { "type": "string" },
          "purpose": { "type": "string" }
        }
      }
    },

    "assumptions": {
      "type": "array",
      "items": { "type": "string" }
    }
  },

  "$defs": {}
}
