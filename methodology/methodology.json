{
  "methodology": "Model-Driven",
  "version": "1.3",
  "title": "Model-Driven Development Methodology",

  "principles": [
    "Dual Artifacts",
    "Progressive Refinement",
    "No Phase Skipping",
    "Traceability",
    "Separation of Concerns",
    "Single Source of Truth",
    "Stable IDs"
  ],

  "naming_conventions": {
    "note": "Patterns are regex. Templates use {placeholder} syntax for human reference only.",
    "files": {
      "use_case":        { "pattern": "^uc-\\d+.*\\.md$",              "template": "uc-{number}-{name}.md",    "location": "ba/use-cases/" },
      "entity":          { "pattern": "^ent-.*\\.json$",               "template": "ent-{name}.json",          "location": "design/entities/" },
      "module_charter":  { "pattern": "^module-charter-.*\\.md$",      "template": "module-charter-{name}.md", "location": "design/modules/{type}/" },
      "module_def":      { "pattern": "^module-.*\\.json$",            "template": "module-{name}.json",       "location": "design/modules/{type}/" },
      "module_spec_dir": { "pattern": "^[a-z0-9-]+$",                  "template": "{module-name}/",           "location": "design/modules/{type}/" }
    },
    "ids": {
      "requirement":         { "pattern": "^BR-\\d+$",                  "template": "BR-{number}",               "example": "BR-001" },
      "business_rule":       { "pattern": "^BRule-\\d+$",               "template": "BRule-{number}",            "example": "BRule-001" },
      "constraint":          { "pattern": "^CON-\\d+$",                 "template": "CON-{number}",              "example": "CON-001" },
      "acceptance_criteria": { "pattern": "^AC-\\d+$",                  "template": "AC-{number}",               "example": "AC-001" },
      "risk":                { "pattern": "^RISK-\\d+$",                "template": "RISK-{number}",             "example": "RISK-001" },
      "module":              { "pattern": "^MOD-\\d+$",                 "template": "MOD-{number}",              "example": "MOD-001" },
      "test_suite":          { "pattern": "^TS-[A-Z]+-\\d+$",           "template": "TS-{MODULE}-{number}",     "example": "TS-CLAIM-001" },
      "test_case":           { "pattern": "^TC-[A-Z]+-\\d{2}-\\d{2}$", "template": "TC-{MODULE}-{suite}-{case}","example": "TC-CLAIM-01-02" }
    }
  },

  "workflow_patterns": {
    "discovery_loop": {
      "label": "Discovery Loop",
      "description": "A general iterative input/analyse/clarify cycle used whenever a phase requires progressive clarification from raw inputs before an artifact can be produced.",
      "steps": [
        "Drop input files into the phase inbox folder",
        "Run the relevant command — the AI reads inputs and produces a first-pass artifact and a question batch",
        "Review and answer the questions in the question batch file (edit responses in place)",
        "Re-run the command — accepted answers are incorporated, completed questions are archived, new questions are generated for remaining gaps",
        "Repeat until the artifact is stable and the question queue is empty or all remaining items are explicitly deferred",
        "Processed input files are moved from the inbox to the processed folder so future runs focus only on new material"
      ],
      "inbox_folder_convention": "Each phase that uses discovery maintains an inbox folder (e.g. ba/discovery/) and a processed folder (e.g. ba/analyzed/). The convention is inbox → processed after the file has been incorporated.",
      "question_lifecycle": {
        "active":    "project/questions.json — current batch, open for user response",
        "deferred":  "project/open-queue.json — items that cannot be resolved yet",
        "completed": "project/completed-Questions.json — items accepted into the artifact baseline"
      },
      "applies_to": [
        "business_analysis",
        "system_design"
      ]
    }
  },

  "phases": [
    {
      "name": "project_initiation",
      "label": "Project Initiation",
      "description": "Bootstrap the workspace with default structure, configuration, and state files. Select the methodology and architecture before analysis begins.",
      "docs": [
        {
          "id": "configuration",
          "label": "Configuration",
          "docType": "root-configuration",
          "file": "configuration.json",
          "required": true
        },
        {
          "id": "application-definition",
          "label": "Application Definition",
          "docType": "application",
          "file": "application/application.json",
          "required": true
        },
        {
          "id": "project-state",
          "label": "Project State",
          "docType": "project-state",
          "file": "project/project-state.json",
          "required": true
        },
        {
          "id": "command-log",
          "label": "Command Log",
          "docType": "command-log",
          "file": "project/logs/command-log.jsonl",
          "required": false
        }
      ]
    },
    {
      "name": "business_analysis",
      "label": "Business Analysis",
      "description": "Analyze source material, derive a requirements baseline, and generate targeted clarification questions.",
      "docs": [
        {
          "id": "domain-brief",
          "label": "Domain Brief",
          "docType": "domain-brief",
          "file": "ba/domain-brief.md",
          "required": false
        },
        {
          "id": "external-references",
          "label": "External References",
          "docType": "external-references",
          "file": "ba/external-references.md",
          "required": false
        },
        {
          "id": "requirements",
          "label": "Requirements",
          "docType": "requirements",
          "file": "ba/requirements.md",
          "required": true
        },
        {
          "id": "analysis-status",
          "label": "Analysis Status",
          "docType": "analysis-status",
          "file": "ba/analysis-status.md",
          "required": true
        },
        {
          "id": "business-functions",
          "label": "Business Functions",
          "docType": "business-functions",
          "file": "ba/business-functions.json",
          "required": true
        },
        {
          "id": "use-cases",
          "label": "Use Cases",
          "docType": "use-case",
          "required": true,
          "scan": {
            "dir": "ba/use-cases",
            "pattern": "^uc-\\d+.*\\.md$"
          }
        },
        {
          "id": "glossary",
          "label": "Glossary",
          "docType": "glossary",
          "file": "ba/glossary.md",
          "required": false
        },
        {
          "id": "questions-batch",
          "label": "Questions Batch",
          "docType": "questions-batch",
          "file": "project/questions.json",
          "required": false
        },
        {
          "id": "open-queue",
          "label": "Open Queue",
          "docType": "open-queue",
          "file": "project/open-queue.json",
          "required": false
        },
        {
          "id": "completed-questions",
          "label": "Completed Questions",
          "docType": "completed-questions",
          "file": "project/completed-Questions.json",
          "required": false
        }
      ]
    },
    {
      "name": "system_design",
      "label": "System Design",
      "description": "Derive architecture, logical data model, module catalog, and module definitions from the requirements baseline.",
      "docs": [
        {
          "id": "architecture",
          "label": "Application Architecture",
          "docType": "architecture",
          "file": "design/application_architecture.json",
          "required": true
        },
        {
          "id": "module-catalog",
          "label": "Module Catalog",
          "docType": "module-catalog",
          "file": "design/modules/module-catalog.json",
          "required": true
        },
        {
          "id": "ldm",
          "label": "Logical Data Model",
          "docType": "logical-data-model",
          "file": "ba/data-model/logical-data-model.json",
          "required": true
        },
        {
          "id": "pdm",
          "label": "Physical Data Model",
          "docType": "physical-data-model",
          "file": "design/data-model/physical-data-model.json",
          "required": false
        },
        {
          "id": "module-charters-svc",
          "label": "Service Module Charters",
          "docType": "module-charter",
          "required": true,
          "scan": {
            "dir": "design/modules/svc",
            "pattern": "^module-charter-.*\\.md$"
          }
        },
        {
          "id": "module-charters-dal",
          "label": "DAL Module Charters",
          "docType": "module-charter",
          "required": true,
          "scan": {
            "dir": "design/modules/dal",
            "pattern": "^module-charter-.*\\.md$"
          }
        },
        {
          "id": "module-specs",
          "label": "Module Specifications",
          "docType": "module-spec",
          "required": true,
          "scan": {
            "dir": "design/modules",
            "pattern": ".*\\.(json|md|ya?ml)$",
            "recursive": true
          }
        }
      ]
    },
    {
      "name": "development",
      "label": "Development",
      "description": "Generate DAL, source code, and sample data from module specifications.",
      "docs": [
        {
          "id": "source-code",
          "label": "Source Code",
          "docType": "source-code",
          "required": true,
          "scan": {
            "dir": "src",
            "pattern": ".*\\.ts$",
            "recursive": true
          }
        },
        {
          "id": "generated-manifest",
          "label": "Generated Manifest",
          "docType": "manifest",
          "file": "generated-manifest.json",
          "required": true
        },
        {
          "id": "module-tests",
          "label": "Module Tests",
          "docType": "module-tests",
          "file": "design/modules/module-tests.json",
          "required": true
        }
      ]
    },
    {
      "name": "governance",
      "label": "Governance",
      "description": "Inspection, validation, assessment, and documentation commands available at any phase.",
      "docs": [
        {
          "id": "erd",
          "label": "Entity Relationship Diagram",
          "docType": "logical-erd",
          "file": "output/docs/diagrams/erd.md",
          "required": false
        },
        {
          "id": "trace-matrix",
          "label": "Traceability Matrix",
          "docType": "trace-matrix",
          "file": "output/docs/trace-matrix.md",
          "required": false
        }
      ]
    }
  ]
}
